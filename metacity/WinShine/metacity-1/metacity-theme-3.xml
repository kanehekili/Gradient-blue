<?xml version="1.0"?>
<metacity_theme>
<info>
  <name>WinShine</name>
  <author>Kanehekili</author>
  <copyright>GPL</copyright>
  <date>2024</date>
  <description>WinShine window decorations — standard DPI (buttons 43x24)</description>
</info>

<!-- ── Geometry ─────────────────────────────────────────────────────────── -->
<!-- Border widths come from WinShine XPM files (4 px, same for all DPIs). -->
<!-- Titlebar height = button_height = 24 px (title_vertical_pad = 0).      -->
<!-- button_width = 43 to fit the wide close button; minimize/maximize are  -->
<!-- 24 px wide and are centred within the 43 px allocation.                -->

<frame_geometry name="normal">
  <distance name="left_width"          value="4"/>
  <distance name="right_width"         value="4"/>
  <distance name="bottom_height"       value="4"/>
  <distance name="left_titlebar_edge"  value="8"/>
  <distance name="right_titlebar_edge" value="8"/>
  <distance name="button_width"        value="43"/>
  <distance name="button_height"       value="24"/>
  <distance name="title_vertical_pad"  value="0"/>
  <border name="title_border"  left="0" right="0" top="0" bottom="0"/>
  <border name="button_border" left="0" right="1" top="0" bottom="0"/>
</frame_geometry>

<frame_geometry name="normal_small_borders" parent="normal">
  <distance name="left_width"          value="0"/>
  <distance name="right_width"         value="0"/>
  <distance name="bottom_height"       value="0"/>
  <distance name="left_titlebar_edge"  value="0"/>
  <distance name="right_titlebar_edge" value="0"/>
</frame_geometry>

<frame_geometry name="utility" title_scale="small" parent="normal"/>

<frame_geometry name="border" has_title="false">
  <distance name="left_width"          value="4"/>
  <distance name="right_width"         value="4"/>
  <distance name="bottom_height"       value="4"/>
  <distance name="left_titlebar_edge"  value="0"/>
  <distance name="right_titlebar_edge" value="0"/>
  <distance name="button_width"        value="0"/>
  <distance name="button_height"       value="0"/>
  <distance name="title_vertical_pad"  value="0"/>
  <border name="title_border"  left="0" right="0" top="0" bottom="0"/>
  <border name="button_border" left="0" right="0" top="0" bottom="0"/>
</frame_geometry>

<!-- ── Button draw_ops ──────────────────────────────────────────────────── -->
<!-- Close: 43x24, fills the full button allocation exactly.                -->
<!-- Minimize / Maximize: 24x24, centred within the 43 px space → x = 9.   -->

<draw_ops name="close_button">
  <image filename="close-active.png"   x="0" y="0" width="object_width" height="object_height"/>
</draw_ops>
<draw_ops name="close_button_prelight">
  <image filename="close-prelight.png" x="0" y="0" width="object_width" height="object_height"/>
</draw_ops>
<draw_ops name="close_button_pressed">
  <image filename="close-pressed.png"  x="0" y="0" width="object_width" height="object_height"/>
</draw_ops>
<draw_ops name="close_button_inactive">
  <image filename="close-inactive.png" x="0" y="0" width="object_width" height="object_height"/>
</draw_ops>

<draw_ops name="minimize_button">
  <image filename="hide-active.png"    x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="minimize_button_prelight">
  <image filename="hide-prelight.png"  x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="minimize_button_pressed">
  <image filename="hide-pressed.png"   x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="minimize_button_inactive">
  <image filename="hide-inactive.png"  x="9" y="0" width="24" height="object_height"/>
</draw_ops>

<draw_ops name="maximize_button">
  <image filename="maximize-active.png"    x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="maximize_button_prelight">
  <image filename="maximize-prelight.png"  x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="maximize_button_pressed">
  <image filename="maximize-pressed.png"   x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="maximize_button_inactive">
  <image filename="maximize-inactive.png"  x="9" y="0" width="24" height="object_height"/>
</draw_ops>

<!-- Restore reuses maximize images (no distinct WinShine restore PNG). -->
<draw_ops name="restore_button">
  <image filename="maximize-active.png"    x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="restore_button_prelight">
  <image filename="maximize-prelight.png"  x="9" y="0" width="24" height="object_height"/>
</draw_ops>
<draw_ops name="restore_button_pressed">
  <image filename="maximize-pressed.png"   x="9" y="0" width="24" height="object_height"/>
</draw_ops>

<!-- Menu button: 20x24, centred → x = 11 (only shown if ButtonLayout includes it). -->
<draw_ops name="menu_button">
  <image filename="menu-active.png"    x="11" y="0" width="20" height="object_height"/>
</draw_ops>
<draw_ops name="menu_button_prelight">
  <image filename="menu-prelight.png"  x="11" y="0" width="20" height="object_height"/>
</draw_ops>
<draw_ops name="menu_button_pressed">
  <image filename="menu-pressed.png"   x="11" y="0" width="20" height="object_height"/>
</draw_ops>
<draw_ops name="menu_button_inactive">
  <image filename="menu-inactive.png"  x="11" y="0" width="20" height="object_height"/>
</draw_ops>

<draw_ops name="blank"/>

<!-- ── Frame backgrounds ────────────────────────────────────────────────── -->
<!-- Border gradient: outer edge #939393 (dark) → inner edge #ddddde (light) -->

<draw_ops name="frame_focused">
  <!-- Window content area -->
  <rectangle color="gtk:light[NORMAL]"
             x="left_width" y="top_height"
             width="width-left_width-right_width"
             height="height-top_height-bottom_height" filled="true"/>
  <!-- Left border: dark-outside → light-inside -->
  <rectangle color="#939393" x="0" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ababab" x="1" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#bfbfbf" x="2" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ddddde" x="3" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <!-- Right border: light-inside → dark-outside -->
  <rectangle color="#ddddde" x="width-4" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#bfbfbf" x="width-3" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ababab" x="width-2" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#939393" x="width-1" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <!-- Bottom border: light-top → dark-bottom -->
  <rectangle color="#ddddde" x="0" y="height-4" width="width" height="1"/>
  <rectangle color="#bfbfbf" x="0" y="height-3" width="width" height="1"/>
  <rectangle color="#ababab" x="0" y="height-2" width="width" height="1"/>
  <rectangle color="#939393" x="0" y="height-1" width="width" height="1"/>
  <!-- Titlebar: left corner + tiled 1-px strip + right corner -->
  <image filename="top-left-active.png"  x="0"       y="0" width="8"        height="top_height"/>
  <image filename="title-1-active.png"   x="8"       y="0" width="width-16" height="top_height"/>
  <image filename="top-right-active.png" x="width-8" y="0" width="8"        height="top_height"/>
</draw_ops>

<draw_ops name="frame_unfocused">
  <rectangle color="gtk:light[NORMAL]"
             x="left_width" y="top_height"
             width="width-left_width-right_width"
             height="height-top_height-bottom_height" filled="true"/>
  <rectangle color="#939393" x="0"      y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ababab" x="1"      y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#bfbfbf" x="2"      y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ddddde" x="3"      y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ddddde" x="width-4" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#bfbfbf" x="width-3" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ababab" x="width-2" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#939393" x="width-1" y="top_height" width="1" height="height-top_height-bottom_height"/>
  <rectangle color="#ddddde" x="0" y="height-4" width="width" height="1"/>
  <rectangle color="#bfbfbf" x="0" y="height-3" width="width" height="1"/>
  <rectangle color="#ababab" x="0" y="height-2" width="width" height="1"/>
  <rectangle color="#939393" x="0" y="height-1" width="width" height="1"/>
  <image filename="top-left-inactive.png"  x="0"       y="0" width="8"        height="top_height"/>
  <image filename="title-1-inactive.png"   x="8"       y="0" width="width-16" height="top_height"/>
  <image filename="top-right-inactive.png" x="width-8" y="0" width="8"        height="top_height"/>
</draw_ops>

<!-- ── Title text ───────────────────────────────────────────────────────── -->
<!-- Shadow colour from themerc: active_text_shadow_color=#efefef            -->

<draw_ops name="title_focused">
  <clip x="0" y="0" width="width" height="height"/>
  <title color="#efefef" x="(width-title_width)/2+1" y="(height-title_height)/2+1"/>
  <title color="#3f3f3f" x="(width-title_width)/2"   y="(height-title_height)/2"/>
</draw_ops>

<draw_ops name="title_unfocused">
  <clip x="0" y="0" width="width" height="height"/>
  <title color="#9c9c9c" x="(width-title_width)/2" y="(height-title_height)/2"/>
</draw_ops>

<!-- ── Frame styles ─────────────────────────────────────────────────────── -->

<frame_style name="normal_focused" geometry="normal">
  <piece position="entire_background" draw_ops="frame_focused"/>
  <piece position="title"             draw_ops="title_focused"/>
  <button function="close"       state="normal"   draw_ops="close_button"/>
  <button function="close"       state="prelight" draw_ops="close_button_prelight"/>
  <button function="close"       state="pressed"  draw_ops="close_button_pressed"/>
  <button function="minimize"    state="normal"   draw_ops="minimize_button"/>
  <button function="minimize"    state="prelight" draw_ops="minimize_button_prelight"/>
  <button function="minimize"    state="pressed"  draw_ops="minimize_button_pressed"/>
  <button function="maximize"    state="normal"   draw_ops="maximize_button"/>
  <button function="maximize"    state="prelight" draw_ops="maximize_button_prelight"/>
  <button function="maximize"    state="pressed"  draw_ops="maximize_button_pressed"/>
  <button function="unmaximize"  state="normal"   draw_ops="restore_button"/>
  <button function="unmaximize"  state="prelight" draw_ops="restore_button_prelight"/>
  <button function="unmaximize"  state="pressed"  draw_ops="restore_button_pressed"/>
  <button function="menu"        state="normal"   draw_ops="menu_button"/>
  <button function="menu"        state="prelight" draw_ops="menu_button_prelight"/>
  <button function="menu"        state="pressed"  draw_ops="menu_button_pressed"/>
  <button function="shade"       state="normal" ><draw_ops></draw_ops></button>
  <button function="shade"       state="pressed"><draw_ops></draw_ops></button>
  <button function="unshade"     state="normal" ><draw_ops></draw_ops></button>
  <button function="unshade"     state="pressed"><draw_ops></draw_ops></button>
  <button function="above"       state="normal" ><draw_ops></draw_ops></button>
  <button function="above"       state="pressed"><draw_ops></draw_ops></button>
  <button function="unabove"     state="normal" ><draw_ops></draw_ops></button>
  <button function="unabove"     state="pressed"><draw_ops></draw_ops></button>
  <button function="stick"       state="normal" ><draw_ops></draw_ops></button>
  <button function="stick"       state="pressed"><draw_ops></draw_ops></button>
  <button function="unstick"     state="normal" ><draw_ops></draw_ops></button>
  <button function="unstick"     state="pressed"><draw_ops></draw_ops></button>
</frame_style>

<frame_style name="normal_unfocused" geometry="normal">
  <piece position="entire_background" draw_ops="frame_unfocused"/>
  <piece position="title"             draw_ops="title_unfocused"/>
  <button function="close"       state="normal"   draw_ops="close_button_inactive"/>
  <button function="close"       state="pressed"  draw_ops="close_button_pressed"/>
  <button function="minimize"    state="normal"   draw_ops="minimize_button_inactive"/>
  <button function="minimize"    state="pressed"  draw_ops="minimize_button_pressed"/>
  <button function="maximize"    state="normal"   draw_ops="maximize_button_inactive"/>
  <button function="maximize"    state="pressed"  draw_ops="maximize_button_pressed"/>
  <button function="unmaximize"  state="normal"   draw_ops="maximize_button_inactive"/>
  <button function="unmaximize"  state="pressed"  draw_ops="maximize_button_pressed"/>
  <button function="menu"        state="normal"   draw_ops="menu_button_inactive"/>
  <button function="menu"        state="pressed"  draw_ops="menu_button_pressed"/>
  <button function="shade"       state="normal" ><draw_ops></draw_ops></button>
  <button function="shade"       state="pressed"><draw_ops></draw_ops></button>
  <button function="unshade"     state="normal" ><draw_ops></draw_ops></button>
  <button function="unshade"     state="pressed"><draw_ops></draw_ops></button>
  <button function="above"       state="normal" ><draw_ops></draw_ops></button>
  <button function="above"       state="pressed"><draw_ops></draw_ops></button>
  <button function="unabove"     state="normal" ><draw_ops></draw_ops></button>
  <button function="unabove"     state="pressed"><draw_ops></draw_ops></button>
  <button function="stick"       state="normal" ><draw_ops></draw_ops></button>
  <button function="stick"       state="pressed"><draw_ops></draw_ops></button>
  <button function="unstick"     state="normal" ><draw_ops></draw_ops></button>
  <button function="unstick"     state="pressed"><draw_ops></draw_ops></button>
</frame_style>

<frame_style name="shaded_focused"       geometry="normal" parent="normal_focused">
  <piece position="title" draw_ops="title_focused"/>
</frame_style>
<frame_style name="shaded_unfocused"     geometry="normal" parent="normal_unfocused">
  <piece position="title" draw_ops="title_unfocused"/>
</frame_style>
<frame_style name="maximized_focused"    geometry="normal_small_borders" parent="normal_focused"/>
<frame_style name="maximized_unfocused"  geometry="normal_small_borders" parent="normal_unfocused"/>
<frame_style name="utility_focused"      geometry="utility" parent="normal_focused">
  <piece position="title" draw_ops="title_focused"/>
</frame_style>
<frame_style name="utility_unfocused"    geometry="utility" parent="normal_unfocused">
  <piece position="title" draw_ops="title_unfocused"/>
</frame_style>
<frame_style name="border_style"         geometry="border" parent="normal_unfocused">
  <piece position="entire_background" draw_ops="frame_unfocused"/>
  <piece position="title"             draw_ops="blank"/>
</frame_style>

<!-- ── Frame style sets ─────────────────────────────────────────────────── -->

<frame_style_set name="normal">
  <frame focus="yes" state="normal"              resize="both" style="normal_focused"/>
  <frame focus="no"  state="normal"              resize="both" style="normal_unfocused"/>
  <frame focus="yes" state="maximized"                         style="maximized_focused"/>
  <frame focus="no"  state="maximized"                         style="maximized_unfocused"/>
  <frame focus="yes" state="shaded"                            style="shaded_focused"/>
  <frame focus="no"  state="shaded"                            style="shaded_unfocused"/>
  <frame focus="yes" state="maximized_and_shaded"              style="maximized_focused"/>
  <frame focus="no"  state="maximized_and_shaded"              style="maximized_unfocused"/>
</frame_style_set>

<frame_style_set name="utility" parent="normal">
  <frame focus="yes" state="normal"  resize="both" style="utility_focused"/>
  <frame focus="no"  state="normal"  resize="both" style="utility_unfocused"/>
  <frame focus="yes" state="shaded"                style="utility_focused"/>
  <frame focus="no"  state="shaded"                style="utility_unfocused"/>
</frame_style_set>

<frame_style_set name="border" parent="normal">
  <frame focus="yes" state="normal"  resize="both" style="border_style"/>
  <frame focus="no"  state="normal"  resize="both" style="border_style"/>
</frame_style_set>

<!-- ── Window type → style set mapping ──────────────────────────────────── -->

<window type="normal"       style_set="normal"/>
<window type="dialog"       style_set="normal"/>
<window type="modal_dialog" style_set="normal"/>
<window type="menu"         style_set="normal"/>
<window type="utility"      style_set="utility"/>
<window type="border"       style_set="border"/>

<menu_icon function="close"      state="normal" draw_ops="close_button"/>
<menu_icon function="maximize"   state="normal" draw_ops="maximize_button"/>
<menu_icon function="unmaximize" state="normal" draw_ops="restore_button"/>
<menu_icon function="minimize"   state="normal" draw_ops="minimize_button"/>

</metacity_theme>
